<ul class="card-text font-weight-light list-group list-group-flush">
  {% for content in data[1] %}
    <li class="list-group-item">
      <div class="row">
        <div class="col-xs-4 cl-sm-4 col-md-4 mt-2 mt-md-0">
          <h6 class="title font-weight-bold ml-1 ml-md-4">{{ content.category }}</h6>
        </div>
        <div class="col-xs-8 cl-sm-8 col-md-8 mt-2 mt-md-0">
          <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem">{{ content.items | join: ', ' }}</h6>
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
